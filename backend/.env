# Application
APP_NAME=LPanda Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres.qmlzushgqskhinpeduuf:lpanda_db12@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# AWS S3

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

S3_BUCKET_NAME=lpanda-submissions
S3_ENDPOINT_URL=

# Site
SITE_BASE_URL=https://meta-sage-xi.vercel.app/

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
EMAIL_FROM=noreply@lpanda.com

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
MAX_FILE_SIZE_MB=50
MAX_SUBMISSION_SIZE_MB=200
ALLOWED_FILE_TYPES=pdf,docx,xlsx,png,jpg,jpeg,gif

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=

# CORS
CORS_ORIGINS=https://meta-sage-xi.vercel.app/

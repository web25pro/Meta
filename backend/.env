# Application
APP_NAME=LPanda Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=4CwR5h48MAW+lwZsuI/v8mLkhO9wg4SPt+RQlmk14kw=
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (using SQLite for local development)
DATABASE_URL=DATABASE_URL=postgresql+asyncpg://postgres.ppuvkmzsdmudhonfzodv:lpanda_db12@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# Redis (using in-memory for local development)
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# AWS S3 (using local MinIO for development)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=lpanda-submissions
S3_ENDPOINT_URL=http://localhost:9000

# Site
SITE_BASE_URL=http://localhost:3000

# SMTP / Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
EMAIL_FROM=noreply@lpanda.com

# JWT
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-87654321
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
MAX_FILE_SIZE_MB=50
MAX_SUBMISSION_SIZE_MB=200
ALLOWED_FILE_TYPES=pdf,docx,xlsx,png,jpg,jpeg,gif

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Application
APP_NAME=LPanda Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_VERSION=v1

# Server
HOST=aws-0-eu-west-1.pooler.supabase.com
PORT=6543

# Database
DATABASE_URL=postgresql://postgres.qmlzushgqskhinpeduuf:lpanda_db12@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=lpanda-submissions
S3_ENDPOINT_URL=

# Site
SITE_BASE_URL=https://meta-sage-xi.vercel.app/

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
MAX_FILE_SIZE_MB=50
MAX_SUBMISSION_SIZE_MB=200
ALLOWED_FILE_TYPES=pdf,docx,xlsx,png,jpg,jpeg,gif

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin bootstrap (optional) — if set, this user is created/promoted to
# Overall_Admin on app startup (idempotent). Set on first deploy to mint the
# first admin without shell access, then clear it.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_USERNAME=

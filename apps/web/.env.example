# API Configuration
# Replace this with the actual domain where your live backend is hosted. Ensure it uses https://
NEXT_PUBLIC_API_URL=https://meta-4bck.onrender.com/api/v1

# Application Configuration
NEXT_PUBLIC_APP_NAME=Meta-Jungle
NEXT_PUBLIC_APP_VERSION=3.0.0

# Feature Flags
# You will likely want analytics on to track community engagement
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# If your live events (like clan clashes or real-time Web3 updates) rely on WebSockets, flip this to true
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
